# Copy to supabase/functions/.env for `supabase functions serve` (never commit .env).
# For hosted projects: `supabase secrets set KEY=value` (repeat per key).

# Optional: public API URL for browser-facing links (storage public URLs from admin edge).
# If unset and SUPABASE_URL uses internal Docker host `kong`, URLs default to http://127.0.0.1:54321.
# SUPABASE_PUBLIC_URL=https://YOUR_PROJECT_REF.supabase.co

# LawHub environment: true = Integration sandbox, false/unset = Production (see LawHubProviderAPI.html).
LAWHUB_SANDBOX=true
# Alias also accepted: LawHubSandbox=true

# OAuth + vendor (LawHub Provider API) — required credentials from LSAC:
# LSAC_VENDOR_ID=
LSAC_CLIENT_ID=
LSAC_CLIENT_SECRET=

# When LAWHUB_SANDBOX=true, defaults are applied automatically:
#   LSAC_BASE_URL=https://providers-api-sandbox.lawhub.org
#   LSAC_SCOPE=https://lawpathb2b.onmicrosoft.com/06b7d783-8a46-43de-a375-07059967cb3b/.default
# When LAWHUB_SANDBOX=false (production), defaults:
#   LSAC_BASE_URL=https://providers-api.lawhub.org
#   LSAC_SCOPE=https://lawpathb2b.onmicrosoft.com/8ffc1f28-b505-42f3-8691-986e25fdd942/.default
# LSAC_TENANT_ID defaults to 09e2500c-c284-4e32-9f4b-1c3c47823cba unless overridden.
# Explicit LSAC_BASE_URL / LSAC_SCOPE / LSAC_TENANT_ID always win over defaults.

# Optional: vendorSystem in logging API
# LSAC_VENDOR_SYSTEM=BetterLSAT

# Temporary kill switch for vendor API calls (useful while waiting on LSAC support).
# When true, users function skips outbound LawHub requests and writes a placeholder coaching id.
# Must be false when testing real sandbox APIs on the LawHubAPI branch.
# LSAC_SKIP_CALLS=true

# Enforce prep-course LSAC entitlement checks (linked + eligible subscription).
# PREP_COURSE_ENFORCE_ENTITLEMENT=true

# Optional local-dev bypass for prep-course learner entitlement checks.
# Use only for development when LSAC linkage/subscription data is unavailable.
# PREP_COURSE_BYPASS_ENTITLEMENT=true

# Optional: override LawHub host for deep-link generation.
# LSAC_DEEPLINK_BASE_URL=https://lawhub.org

# Stripe billing (Core $70/mo, Live $129/mo + LawHub Advantage yearly). Localhost always uses TEST keys.
# STRIPE_LIVE_MODE=false
# STRIPE_SECRET_KEY_TEST=
# STRIPE_SECRET_KEY_LIVE=
# STRIPE_WEBHOOK_SECRET_TEST=
# STRIPE_WEBHOOK_SECRET_LIVE=
#
# Sandbox/test prices (product ids for reference only — checkout uses price ids):
#   Core: prod_UnCSydaUrNNh2W → price_1Tnc3ORYMHefItxyp2qzWSWU
#   Live: prod_UnCSgEzsbaU440 → price_1Tnc3nRYMHefItxyV07ZK1iX
#   LawHub Advantage: prod_UnCTRiUDxfzSgJ → price_1Tnc4zRYMHefItxyJ9VIwhdJ
STRIPE_PRICE_ID_CORE_TEST=price_1Tnc3ORYMHefItxyp2qzWSWU
STRIPE_PRICE_ID_LIVE_MONTHLY_TEST=price_1Tnc3nRYMHefItxyV07ZK1iX
STRIPE_PRICE_ID_LSAC_YEARLY_TEST=price_1Tnc4zRYMHefItxyJ9VIwhdJ
#
# Live prices:
#   Core: prod_UnCLYZ5biIlHFE → price_1TnbwhRmLjOWCB3OyC6OBXzo
#   Live: prod_UnCN3DAKqdonOw → price_1TnbyYRmLjOWCB3OHraXMK4e
#   LawHub Advantage: prod_UnCN96nZ96U18u → price_1Tnbz3RmLjOWCB3O9TMbOvvC
STRIPE_PRICE_ID_CORE_LIVE=price_1TnbwhRmLjOWCB3OyC6OBXzo
STRIPE_PRICE_ID_LIVE_MONTHLY_LIVE=price_1TnbyYRmLjOWCB3OHraXMK4e
STRIPE_PRICE_ID_LSAC_YEARLY_LIVE=price_1Tnbz3RmLjOWCB3O9TMbOvvC
# STRIPE_PUBLISHABLE_KEY_TEST=
# STRIPE_PUBLISHABLE_KEY_LIVE=
# Checkout success/cancel redirects (Stripe). Production:
APP_BASE_URL=https://better-lsat-qbank.vercel.app
# Local edge functions only:
# APP_BASE_URL=http://localhost:5173

# Required for lsac-sync function authorization header `x-lsac-sync-key`.
# LSAC_SYNC_KEY=change-me
