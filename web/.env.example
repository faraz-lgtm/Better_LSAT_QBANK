# Copy to .env.local for local dev. Values from `supabase start` (API URL + anon key).
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Never put LawHub / LSAC client secrets here — those belong in Edge Function secrets only.

# Optional: set to 1 to allow unauthenticated PrepTest practice UI in non-production builds
# (e.g. `vite preview`). Default `pnpm dev` already uses emulator mode and does not need this.
# VITE_STUDENT_UI_PREVIEW=1
